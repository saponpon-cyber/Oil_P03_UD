  } else { rbar.style.display='none'; }

  document.getElementById('reqFormSection').style.display='none';
  document.getElementById('reqPreviewSection').style.display='block';
  window.scrollTo(0,0);
}

function backToForm() {
  document.getElementById('reqPreviewSection').style.display='none';
  document.getElementById('reqFormSection').style.display='block';
}

// ═══ SAVE TO PENDING (บันทึกรอการอนุมัติ) ═══
async function saveToRecord() {
  if (cart.length===0) { toast('⚠️ ไม่มีรายการ','warn'); return; }
  const btn=document.querySelector('#reqPreviewSection .green'), spin=document.getElementById('reqSpinner2');
  btn.disabled=true; spin.style.display='block';

  for (const item of cart) {
    const payload={...item, action:'request', photoUrls:undefined, photoFiles:undefined};
    if (GAS_URL) try { await fetch(GAS_URL,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}); } catch(e){}
    pending.push({...item, status:'pending'});
  }
  savePending();
  btn.disabled=false; spin.style.display='none';
  cart=[];
  clearItemForm(); renderCart();
  document.getElementById('reqPreviewSection').style.display='none';
  document.getElementById('reqFormSection').style.display='block';
  toast(`✅ บันทึก ${pending.filter(p=>p.status==='pending').length} รายการรอการอนุมัติแล้ว`, 'success');
  renderRecordList();
}

