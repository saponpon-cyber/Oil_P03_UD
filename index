// ═══ FILL MODAL (simplified - use request data directly) ═══
function openFillModal(idx) {
  curFillItem = pending[idx];
  const r = curFillItem;
  const isOver = r.rateStatus === 'เกินเรท';
  const mLabel = r.machineUnit === 'hr' ? 'ชม.' : 'กม.';

  // Main info block
  document.getElementById('mFillInfo').innerHTML =
    `<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
      <span style="font-size:16px;font-weight:700">${mi(r.machineType)} ${r.machineType} · ${r.plateNo}</span>
      <span style="font-family:var(--mono);font-size:20px;font-weight:700;color:var(--accent)">${r.liters} ล.</span>
    </div>
    <div style="opacity:.75">📅 ${fmtD(r.fuelDate)} &nbsp;·&nbsp; 👤 ${r.driverName}${r.project?' · '+r.project:''}</div>`;

  // Meter block
  const meterEl = document.getElementById('mFillMeter');
  const meterContent = document.getElementById('mFillMeterContent');
  if (r.meterEnd || r.distOrHr || r.consumeRate) {
    meterEl.style.display = 'block';
    let mc = '';
    if (r.lastFuelDate && r.meterStart) mc += `${mLabel}ครั้งล่าสุด (${fmtD(r.lastFuelDate)}): <strong>${r.meterStart}</strong><br>`;
    if (r.meterEnd) mc += `${mLabel}ปัจจุบัน (${fmtD(r.fuelDate)}): <strong>${r.meterEnd}</strong><br>`;
    if (r.distOrHr)    mc += `ระยะที่ใช้: <strong>${r.distOrHr}</strong><br>`;
    if (r.consumeRate) mc += `อัตราสิ้นเปลือง: <strong>${r.consumeRate}</strong>`;
    meterContent.innerHTML = mc;
  } else {
    meterEl.style.display = 'none';
  }

  // Rate status
  const rateEl = document.getElementById('mFillRate');
  if (r.consumeRate) {
    rateEl.style.display = 'flex';
    rateEl.style.background = isOver ? 'var(--red-bg)' : 'var(--green-bg)';
    rateEl.style.color = isOver ? 'var(--red)' : 'var(--green-mid)';
    rateEl.innerHTML = `<span>${isOver?'⚠️':'✅'}</span> ${r.consumeRate} — ${isOver?'เกินเรทมาตรฐาน':'ปกติ'}`;
  } else {
    rateEl.style.display = 'none';
  }

  document.getElementById('fillRecorder').value = '';
  document.getElementById('fillSpinner').style.display = 'none';
  openModal('modalFill');
}

async function confirmFill() {
  const r = curFillItem;
  const btn = document.querySelector('#modalFill .green');
  const spin = document.getElementById('fillSpinner');
  btn.disabled = true; spin.style.display = 'block';

  const rec = {
    action: 'record',
    requestId: r.id,
    fuelDate: r.fuelDate,
    plateNo: r.plateNo,
    machineType: r.machineType,
    machineUnit: r.machineUnit,
    machineMax: r.machineMax,
    actualLiters: r.liters,
    pricePerLiter: 0,
    totalCost: '0',
    meterStart: r.meterStart || '',
    meterEnd: r.meterEnd || '',
    distOrHr: r.distOrHr || '',
    consumeRate: r.consumeRate || '',
    rateStatus: r.rateStatus || 'ไม่มีข้อมูล',
    fuelSource: 'ตามใบขอเบิก',
    driverName: r.driverName,
    recorderName: document.getElementById('fillRecorder').value,
    project: r.project || '',
    remark: r.reason || '',
    recordedAt: new Date().toISOString()
  };

  if (GAS_URL) try { await fetch(GAS_URL,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(rec)}); } catch(e){}

  records.unshift(rec);
  saveRecords();
  const pidx = pending.indexOf(curFillItem);
  if (pidx > -1) pending.splice(pidx, 1);
  savePending();

  // Auto stock-out entry
  const stockBal = calcStockBalance();
  stockLedger.push({
    type: 'out',
    date: rec.fuelDate,
    liters: rec.actualLiters,
    ref: `จ่าย: ${rec.machineType} ${rec.plateNo}`,
    recorder: rec.recorderName || rec.driverName,
    note: rec.distOrHr ? `${rec.distOrHr}${rec.consumeRate ? ' · '+rec.consumeRate : ''}` : '',
    balance: stockBal - rec.actualLiters,
    ts: new Date().toISOString()
  });
  saveStock();

  btn.disabled = false; spin.style.display = 'none';
  closeModal('modalFill');
  renderRecordList();
  renderDash();
  toast(rec.rateStatus==='เกินเรท' ? '⚠️ บันทึกแล้ว — เกินเรท!' : '✅ บันทึกสำเร็จ!',
        rec.rateStatus==='เกินเรท' ? 'warn' : 'success');
}

// ═══ DASHBOARD ═══
function renderDash() {
  const now = new Date();
  if (dashYear===undefined) { dashYear=now.getFullYear(); dashMonthIdx=now.getMonth(); }
  const monthNames=['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
  document.getElementById('dashMonthLabel').textContent = monthNames[dashMonthIdx]+' '+(dashYear+543);

  const monthRecs = records.filter(r => {
    if (!r.recordedAt && !r.fuelDate) return false;
    const d = new Date(r.recordedAt || r.fuelDate);
    return d.getFullYear()===dashYear && d.getMonth()===dashMonthIdx;
  });

  document.getElementById('dStatCount').textContent = monthRecs.length;
  const totalL = monthRecs.reduce((s,r)=>s+(parseFloat(r.actualLiters)||0), 0);
  document.getElementById('dStatLiters').textContent = totalL.toFixed(0);
  const totalC = monthRecs.reduce((s,r)=>s+(parseFloat(r.totalCost)||0), 0);
  document.getElementById('dStatCost').textContent = totalC > 0 ? (totalC/1000).toFixed(1)+'K' : '0';
  document.getElementById('dStatOver').textContent = monthRecs.filter(r=>r.rateStatus==='เกินเรท').length;

  // ── Bar chart: group by machine type, sub-rows by plate ──
  const byMachine = {};
  monthRecs.forEach(r => {
    if (!byMachine[r.machineType]) byMachine[r.machineType] = { liters:0, count:0, over:0, plates:{} };
    const m = byMachine[r.machineType];
    m.liters += parseFloat(r.actualLiters)||0;
    m.count++;
    if (r.rateStatus==='เกินเรท') m.over++;
    const plate = r.plateNo || 'ไม่ระบุ';
    if (!m.plates[plate]) m.plates[plate] = { liters:0, count:0, over:0 };
    m.plates[plate].liters += parseFloat(r.actualLiters)||0;
    m.plates[plate].count++;
    if (r.rateStatus==='เกินเรท') m.plates[plate].over++;
  });

  const sorted = Object.entries(byMachine).sort((a,b)=>b[1].liters-a[1].liters);
  const maxL = sorted.length > 0 ? sorted[0][1].liters : 1;
  const chart = document.getElementById('machineChart');

  if (sorted.length === 0) {
    chart.innerHTML = '<div style="text-align:center;padding:20px;color:var(--gray-400);font-size:13px">ไม่มีข้อมูลเดือนนี้</div>';
  } else {
    chart.innerHTML = sorted.map(([type, data]) => {
      const pct = Math.round(data.liters / maxL * 100);
      const isOver = data.over > 0;
      const barContent = pct > 18 ? `<span class="bar-val">${data.liters.toFixed(0)} ล.</span>` : '';
      const outsideVal = pct <= 18 ? `<span class="bar-val outside">${data.liters.toFixed(0)} ล.</span>` : '';

      // Sub-rows per plate
      const plateSorted = Object.entries(data.plates).sort((a,b)=>b[1].liters-a[1].liters);
      const subRows = plateSorted.map(([plate, pdata]) => {
        const subPct = Math.round(pdata.liters / data.liters * 100);
        const pOver = pdata.over > 0;
        return `<div class="bar-sub-row">
          <span class="bar-sub-lbl">${plate}</span>
          <div class="bar-sub-track">
            <div class="bar-sub-fill${pOver?' over':''}" style="width:${subPct}%"></div>
          </div>
          <span class="bar-sub-val${pOver?' warn':''}">${pdata.liters.toFixed(0)} ล.${pOver?' ⚠️':''}</span>
        </div>`;
      }).join('');

      return `<div class="bar-group">
        <div class="bar-row" onclick="toggleSub('sub_${type.replace(/\s/g,'_')}')">
          <span class="bar-lbl">${mi(type)} ${type}</span>
          <div class="bar-track">
            <div class="bar-fill${isOver?' over':''}" style="width:${pct}%">${barContent}</div>
          </div>
          ${outsideVal}
          <span class="bar-expand">${plateSorted.length > 1 ? '▸' : ''}</span>
        </div>
        ${plateSorted.length > 0 ? `<div class="bar-subs" id="sub_${type.replace(/\s/g,'_')}">${subRows}</div>` : ''}
      </div>`;
    }).join('');
  }

  // ── History list ──
  const hist = document.getElementById('dashHistory');
  if (monthRecs.length === 0) {
    hist.innerHTML = '<div class="empty"><div class="ei">📋</div><div class="et">ยังไม่มีข้อมูล</div></div>';
    return;
  }
  hist.innerHTML = monthRecs.slice(0,20).map(r => {
    const isOver = r.rateStatus === 'เกินเรท';
    const origIdx = records.indexOf(r);
    return `<div class="hist-item">
      <div class="hi-icon">${mi(r.machineType)}</div>
      <div class="hi-body">
        <div class="hi-top">
          <div class="hi-machine">${r.machineType} · ${r.plateNo}</div>
          <div style="display:flex;align-items:center;gap:8px">
            <div class="hi-liters">${r.actualLiters} ล.</div>
            <button onclick="deleteRecord(${origIdx})" style="background:none;border:none;color:var(--gray-400);cursor:pointer;font-size:14px;padding:0" title="ลบ">🗑️</button>
          </div>
        </div>
        <div class="hi-detail">
          📅 ${fmtD(r.fuelDate)} · 👤 ${r.driverName}${r.project?' · '+r.project:''}
          ${r.distOrHr?' · '+r.distOrHr:''}
        </div>
        ${r.consumeRate?`<div class="hi-rate ${isOver?'warn':'ok'}">${isOver?'⚠️':'✅'} ${r.consumeRate}</div>`:''}
      </div>
    </div>`;
  }).join('');
}

function toggleSub(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.classList.toggle('open');
}

// ═══ DELETE FUNCTIONS ═══
function deletePending(idx) {
  const item = pending[idx];
  if (!item) return;
  if (!confirm(`ลบรายการ "${item.machineType} ${item.plateNo}" ออก?`)) return;
  pending.splice(idx, 1);
  savePending();
  renderRecordList();
  toast('🗑️ ลบรายการรอบันทึกแล้ว', '');
}

function deleteRecord(idx) {
  const rec = records[idx];
  if (!rec) return;
  if (!confirm(`ลบประวัติ "${rec.machineType} ${rec.plateNo}" วันที่ ${fmtD(rec.fuelDate)}?\n\nหากบันทึกเป็น "จ่ายออก" ในคลัง ระบบจะลบรายการคลังออกด้วย`)) return;

  // Also remove matching stock-out entry
  const recTs = rec.recordedAt;
  const stockIdx = stockLedger.findIndex(t =>
    t.type === 'out' && t.ts === recTs
  );
  if (stockIdx > -1) {
    stockLedger.splice(stockIdx, 1);
    saveStock();
  }

  records.splice(idx, 1);
  saveRecords();
  renderDash();
  renderStock();
  toast('🗑️ ลบประวัติการบันทึกแล้ว', '');
}

function deleteStockEntry(idx) {
  const tx = stockLedger[idx];
  if (!tx) return;
  const label = tx.type === 'in' ? `รับเข้า ${tx.liters} ล. วันที่ ${fmtD(tx.date)}` : `จ่ายออก ${tx.liters} ล. (${tx.ref||''})`;
  if (!confirm(`ลบรายการคลัง "${label}"?`)) return;
  stockLedger.splice(idx, 1);
  saveStock();
  renderStock();
  toast('🗑️ ลบรายการคลังแล้ว', '');
}

// ═══ STOCK FUNCTIONS ═══
function calcStockBalance() {
  return stockLedger.reduce((bal, tx) => {
    return tx.type === 'in' ? bal + (parseFloat(tx.liters)||0) : bal - (parseFloat(tx.liters)||0);
  }, 0);
}

function calcStockTotalIn() {
  return stockLedger.filter(t=>t.type==='in').reduce((s,t)=>s+(parseFloat(t.liters)||0), 0);
}

function calcStockTotalOut() {
  return stockLedger.filter(t=>t.type==='out').reduce((s,t)=>s+(parseFloat(t.liters)||0), 0);
}

function renderStock() {
  const bal    = calcStockBalance();
  const totalIn  = calcStockTotalIn();
  const totalOut = calcStockTotalOut();
  const LOW_THRESHOLD = 50; // ลิตร

  // Summary card
  document.getElementById('stockBalance').textContent = bal.toFixed(0);
  document.getElementById('stockTotalIn').textContent  = totalIn.toFixed(0) + ' ล.';
  document.getElementById('stockTotalOut').textContent = totalOut.toFixed(0) + ' ล.';

  // Level bar
  const pct = totalIn > 0 ? Math.min(100, Math.round(bal / totalIn * 100)) : 0;
  const fill = document.getElementById('stockBarFill');
  fill.style.width = pct + '%';
  fill.className = 'stock-bar-fill' + (bal < LOW_THRESHOLD ? ' low' : '');
  document.getElementById('stockBarMax').textContent = totalIn.toFixed(0) + ' ล. (รับเข้ารวม)';

  // Low stock warning
  document.getElementById('stockWarn').style.display = (bal < LOW_THRESHOLD && totalIn > 0) ? 'flex' : 'none';

  // Transaction log
  renderStockLog();
}

function stockFilter(mode) {
  stockFilterMode = mode;
  document.querySelectorAll('.stk-filter').forEach(b => b.classList.remove('active'));
  const map = { all:'sfAll', in:'sfIn', out:'sfOut' };
  document.getElementById(map[mode]).classList.add('active');
  renderStockLog();
}

function renderStockLog() {
  const log = document.getElementById('stockLog');
  let items = [...stockLedger].reverse(); // newest first
  if (stockFilterMode === 'in')  items = items.filter(t => t.type === 'in');
  if (stockFilterMode === 'out') items = items.filter(t => t.type === 'out');

  if (items.length === 0) {
    log.innerHTML = '<div class="empty"><div class="ei">📒</div><div class="et">ยังไม่มีรายการ</div><div class="es">กด "บันทึกรับน้ำมันเข้าคลัง" เพื่อเริ่มต้น</div></div>';
    return;
  }

  // Rebuild running balance for display
  const balMap = buildBalanceMap();

  log.innerHTML = items.map(tx => {
    const isIn = tx.type === 'in';
    const bal  = balMap[tx.ts] !== undefined ? balMap[tx.ts].toFixed(0) : '—';
    const origIdx = stockLedger.indexOf(tx);
    return `<div class="stk-item">
      <div class="stk-dot ${isIn?'in':'out'}">${isIn ? '📥' : '📤'}</div>
      <div class="stk-body">
        <div class="stk-top">
          <div class="stk-title">${isIn ? 'รับน้ำมันเข้า' : tx.ref || 'จ่ายออก'}</div>
          <div style="display:flex;align-items:center;gap:8px">
            <div class="stk-amount ${isIn?'in':'out'}">${isIn?'+':'-'}${parseFloat(tx.liters).toFixed(0)} ล.</div>
            <button onclick="deleteStockEntry(${origIdx})" style="background:none;border:none;color:var(--gray-400);cursor:pointer;font-size:14px;padding:0 2px" title="ลบ">🗑️</button>
          </div>
        </div>
        <div class="stk-detail">
          📅 ${fmtD(tx.date)}
          ${tx.supplier ? ' · 🚚 '+tx.supplier : ''}
          ${tx.ref && isIn ? ' · เลขที่: '+tx.ref : ''}
          ${tx.recorder ? ' · 👤 '+tx.recorder : ''}
          ${tx.note ? '<br>📝 '+tx.note : ''}
          ${tx.priceTotal&&parseFloat(tx.priceTotal)>0 ? ' · 💰 '+parseFloat(tx.priceTotal).toLocaleString('th-TH')+'฿' : ''}
        </div>
        <div class="stk-bal">คงเหลือ: ${bal} ล.</div>
      </div>
    </div>`;
  }).join('');
}

function buildBalanceMap() {
  // Build a map of ts -> running balance after that transaction
  let bal = 0;
  const map = {};
  stockLedger.forEach(tx => {
    bal = tx.type === 'in' ? bal + (parseFloat(tx.liters)||0) : bal - (parseFloat(tx.liters)||0);
    map[tx.ts] = bal;
  });
  return map;
}

function openStockIn() {
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('siDate').value = today;
  document.getElementById('siLiters').value = '';
  document.getElementById('siPrice').value = '';
  document.getElementById('siSupplier').value = '';
  document.getElementById('siRef').value = '';
  document.getElementById('siRecorder').value = '';
  document.getElementById('siNote').value = '';
  document.getElementById('siPreview').style.display = 'none';

  // Show preview on input
  const updatePreview = () => {
    const liters = parseFloat(document.getElementById('siLiters').value) || 0;
    if (liters > 0) {
      const cur = calcStockBalance();
      document.getElementById('siPreview').style.display = 'block';
      document.getElementById('siCurrentBal').textContent = cur.toFixed(0) + ' ล.';
      document.getElementById('siNewLiters').textContent  = '+' + liters.toFixed(0) + ' ล.';
      document.getElementById('siNewBal').textContent     = (cur + liters).toFixed(0) + ' ล.';
    } else {
      document.getElementById('siPreview').style.display = 'none';
    }
  };
  document.getElementById('siLiters').oninput = updatePreview;
  openModal('modalStockIn');
}

function confirmStockIn() {
  const liters   = parseFloat(document.getElementById('siLiters').value);
  const date     = document.getElementById('siDate').value;
  if (!liters || liters <= 0) { toast('⚠️ กรุณากรอกจำนวนลิตร','warn'); return; }
  if (!date) { toast('⚠️ กรุณาเลือกวันที่','warn'); return; }

  const price    = parseFloat(document.getElementById('siPrice').value) || 0;
  const ts       = new Date().toISOString();
  const newBal   = calcStockBalance() + liters;

  stockLedger.push({
    type: 'in',
    date,
    liters,
    supplier:   document.getElementById('siSupplier').value,
    ref:        document.getElementById('siRef').value,
    recorder:   document.getElementById('siRecorder').value,
    note:       document.getElementById('siNote').value,
    pricePerLiter: price,
    priceTotal: price > 0 ? (price * liters).toFixed(2) : 0,
    balance: newBal,
    ts
  });
  saveStock();
  closeModal('modalStockIn');
  renderStock();
  toast(`✅ รับน้ำมันเข้า ${liters.toFixed(0)} ล. — คงเหลือ ${newBal.toFixed(0)} ล.`, 'success');
}

function saveStock() { localStorage.setItem('stockLedger', JSON.stringify(stockLedger)); }

// ═══ UTILS ═══
function mi(type){ return {'แม็คโคร':'🚜','แทรกเตอร์':'🚛','เทรนเลอร์':'🚚','สิบล้อ':'🚛','กระบะ':'🛻','มอเตอร์ไซค์':'🏍️','เครน':'🏗️','เครื่องปั่นไฟ':'⚡','รถน้ำ':'🚒','รถบด':'🛞'}[type]||'🚗'; }
function fmtD(d){ if(!d)return''; const p=d.split('-'); return `${p[2]}/${p[1]}/${parseInt(p[0])-543}`; }
function setTomorrow(){ const t=new Date(); t.setDate(t.getDate()+1); document.getElementById('reqFuelDate').value=t.toISOString().split('T')[0]; }

function clearItemForm() {
  ['reqPlateNo','reqLiters','reqReason','reqProject','reqLastFuelDate','reqMileS','reqMileE','reqHrS','reqHrE'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  setTomorrow();
  curMachine=null; reqPhotos=[];
  document.querySelectorAll('#reqMachineGrid .mbtn').forEach(b=>b.classList.remove('sel'));
  document.getElementById('reqRateInfo').style.display='none';
  document.getElementById('reqCalcLive').style.display='none';
  document.getElementById('reqMeter_km').style.display='';
  document.getElementById('reqMeter_hr').style.display='none';
  document.getElementById('reqPreviews').innerHTML='';
  document.getElementById('lastFuelBanner').style.display='none';
}

function saveRecords(){ localStorage.setItem('fuelRecords',JSON.stringify(records)); }
function savePending(){ localStorage.setItem('fuelPending',JSON.stringify(pending)); }
function openModal(id){ document.getElementById(id).classList.add('show'); document.body.style.overflow='hidden'; }
function closeModal(id){ document.getElementById(id).classList.remove('show'); document.body.style.overflow=''; }
document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)closeModal(m.id);}));
function toggleStep(id){ document.getElementById(id).classList.toggle('open'); }

function saveGasUrl(){ const url=document.getElementById('gasUrl').value.trim(); if(!url){toast('⚠️ กรุณากรอก URL','warn');return;} GAS_URL=url; localStorage.setItem('gasUrl',url); toast('✅ บันทึก URL แล้ว','success'); setConn('on','บันทึก URL แล้ว — กด "ทดสอบ" เพื่อยืนยัน'); }
function loadGasUrl(){ const url=localStorage.getItem('gasUrl')||''; document.getElementById('gasUrl').value=url; if(url)setConn('on','มี URL บันทึกแล้ว'); else setConn('','ยังไม่ได้ตั้งค่า URL'); }
async function testConn(){ if(!GAS_URL){toast('⚠️ กรุณากรอก URL','warn');return;} setConn('','กำลังทดสอบ...'); try{ const res=await fetch(GAS_URL); const d=await res.json(); if(d.status==='ok'){setConn('on','✅ เชื่อมต่อสำเร็จ');toast('✅ เชื่อมต่อ Google Sheets สำเร็จ!','success');}else throw new Error(d.msg); }catch(e){setConn('err','เชื่อมต่อไม่ได้ — ตรวจสอบ URL');toast('❌ เชื่อมต่อไม่ได้','error');} }
function setConn(state,msg){ document.getElementById('statusDot').className='sdot'+(state?' '+state:''); document.getElementById('statusText').textContent=msg; }
function copyGasCode(){ const el=document.getElementById('gasCodeBlock'); navigator.clipboard.writeText(el.innerText.replace(/^คัดลอก\n/,'')).then(()=>toast('✅ คัดลอกโค้ดแล้ว','success')); }

let toastTimer;
function toast(msg,type=''){ const t=document.getElementById('toast'); const icons={success:'✅',error:'❌',warn:'⚠️'}; document.getElementById('toastMsg').textContent=msg; document.getElementById('toastIcon').textContent=icons[type]||'ℹ️'; t.className='toast show '+type; clearTimeout(toastTimer); toastTimer=setTimeout(()=>t.classList.remove('show'),3800); }
</script>
