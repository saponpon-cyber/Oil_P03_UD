<span class="cc">// ===== Google Apps Script =====</span>
<span class="ck">const</span> SHEET_ID   = <span class="cs">"YOUR_SPREADSHEET_ID"</span>;
<span class="ck">const</span> PM_EMAIL   = <span class="cs">"pm@yourcompany.com"</span>;
<span class="ck">const</span> SHEET_REQ  = <span class="cs">"ใบขอเบิก"</span>;
<span class="ck">const</span> SHEET_REC  = <span class="cs">"บันทึกน้ำมัน"</span>;

<span class="ck">function</span> doGet(e) {
  <span class="ck">return</span> respond({status:<span class="cs">"ok"</span>,msg:<span class="cs">"Fuel API Ready"</span>});
}
<span class="ck">function</span> doPost(e) {
  <span class="ck">try</span> {
    <span class="ck">const</span> d = JSON.parse(e.postData.contents);
    <span class="ck">if</span>(d.action===<span class="cs">"request"</span>) <span class="ck">return</span> saveRequest(d);
    <span class="ck">if</span>(d.action===<span class="cs">"record"</span>)  <span class="ck">return</span> saveRecord(d);
    <span class="ck">return</span> respond({status:<span class="cs">"error"</span>,msg:<span class="cs">"unknown"</span>});
  } <span class="ck">catch</span>(err){ <span class="ck">return</span> respond({status:<span class="cs">"error"</span>,msg:err.toString()}); }
}
<span class="ck">function</span> saveRequest(d) {
  <span class="ck">const</span> sh = getOrCreate(SHEET_REQ,[
    <span class="cs">"ID"</span>,<span class="cs">"วันที่ขอ"</span>,<span class="cs">"วันที่เติม"</span>,<span class="cs">"ทะเบียน"</span>,<span class="cs">"ประเภท"</span>,
    <span class="cs">"ลิตร"</span>,<span class="cs">"หน่วยงาน"</span>,<span class="cs">"ผู้ขับ"</span>,<span class="cs">"มิเตอร์เริ่ม"</span>,
    <span class="cs">"มิเตอร์สิ้นสุด"</span>,<span class="cs">"ระยะ/ชม."</span>,<span class="cs">"อัตราสิ้นเปลือง"</span>,<span class="cs">"สถานะเรท"</span>,<span class="cs">"เหตุผล"</span>
  ]);
  sh.appendRow([d.id,<span class="ck">new</span> Date(),d.fuelDate,d.plateNo,d.machineType,
    d.liters,d.project,d.driverName,d.meterStart,d.meterEnd,
    d.distOrHr,d.consumeRate,d.rateStatus,d.reason]);
  MailApp.sendEmail(PM_EMAIL,
    <span class="cs">`📋 ขอเบิก: ${d.machineType} ${d.plateNo} — ${d.liters} ล. (${d.fuelDate})`</span>,
    <span class="cs">`${d.machineType} ${d.plateNo}\n${d.liters} ลิตร\nวันที่: ${d.fuelDate}\nผู้ขับ: ${d.driverName}\nมิเตอร์: ${d.meterStart} → ${d.meterEnd}\nระยะ: ${d.distOrHr}\nอัตรา: ${d.consumeRate}`</span>);
  <span class="ck">return</span> respond({status:<span class="cs">"ok"</span>});
}
<span class="ck">function</span> saveRecord(d) {
  <span class="ck">const</span> sh = getOrCreate(SHEET_REC,[
    <span class="cs">"Timestamp"</span>,<span class="cs">"RequestID"</span>,<span class="cs">"วันที่เติม"</span>,<span class="cs">"ทะเบียน"</span>,<span class="cs">"ประเภท"</span>,
    <span class="cs">"ลิตรจริง"</span>,<span class="cs">"ราคา/ลิตร"</span>,<span class="cs">"รวมบาท"</span>,<span class="cs">"มิเตอร์เริ่ม"</span>,<span class="cs">"มิเตอร์สิ้นสุด"</span>,
    <span class="cs">"ระยะ/ชม."</span>,<span class="cs">"อัตราสิ้นเปลือง"</span>,<span class="cs">"สถานะเรท"</span>,<span class="cs">"แหล่งน้ำมัน"</span>,
    <span class="cs">"ผู้ขับ"</span>,<span class="cs">"ผู้บันทึก"</span>,<span class="cs">"หน่วยงาน"</span>,<span class="cs">"หมายเหตุ"</span>
  ]);
  sh.appendRow([<span class="ck">new</span> Date(),d.requestId,d.fuelDate,d.plateNo,d.machineType,
    d.actualLiters,d.pricePerLiter,d.totalCost,d.meterStart,d.meterEnd,
    d.distOrHr,d.consumeRate,d.rateStatus,d.fuelSource,
    d.driverName,d.recorderName,d.project,d.remark]);
  <span class="ck">if</span>(d.rateStatus===<span class="cs">"เกินเรท"</span>)
    MailApp.sendEmail(PM_EMAIL,
      <span class="cs">`⚠️ เกินเรท: ${d.machineType} ${d.plateNo} — ${d.consumeRate}`</span>,
      <span class="cs">`ทะเบียน: ${d.plateNo}\nอัตรา: ${d.consumeRate}\nวันที่: ${d.fuelDate}`</span>);
  <span class="ck">return</span> respond({status:<span class="cs">"ok"</span>});
}
<span class="ck">function</span> getOrCreate(name,headers) {
  <span class="ck">const</span> ss=SpreadsheetApp.openById(SHEET_ID);
  <span class="ck">let</span> sh=ss.getSheetByName(name);
  <span class="ck">if</span>(!sh){
    sh=ss.insertSheet(name);
    sh.appendRow(headers);
    sh.getRange(1,1,1,headers.length).setBackground(<span class="cs">"#0f2744"</span>).setFontColor(<span class="cs">"#fff"</span>).setFontWeight(<span class="cs">"bold"</span>);
    sh.setFrozenRows(1);
  }
  <span class="ck">return</span> sh;
}
<span class="ck">function</span> respond(obj){
  <span class="ck">return</span> ContentService.createTextOutput(JSON.stringify(obj)).setMimeType(ContentService.MimeType.JSON);
}</div>
