<script>
// ═══ STATE ═══
let GAS_URL    = localStorage.getItem('gasUrl') || '';
let records    = JSON.parse(localStorage.getItem('fuelRecords') || '[]');
let pending    = JSON.parse(localStorage.getItem('fuelPending') || '[]');
let stockLedger = JSON.parse(localStorage.getItem('stockLedger') || '[]'); // [{type:'in'|'out', date, liters, ...}]
let cart       = [];
let reqPhotos  = [];
let fillPhotos = [];
let curMachine = null;
let curFillItem = null;
let dashYear, dashMonthIdx;
let stockFilterMode = 'all';

// ═══ INIT ═══
document.addEventListener('DOMContentLoaded', () => {
  setTomorrow();
  loadGasUrl();
  renderCart();
  renderRecordList();
  renderStock();
  renderDash();
});

// ═══ TABS ═══
function switchTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('panel-'+tab).classList.add('active');
  document.getElementById('tab-'+tab).classList.add('active');
  if (tab==='record') renderRecordList();
  if (tab==='stock')  renderStock();
  if (tab==='dash')   renderDash();
}

// ═══ MACHINE SELECT ═══
function selMachine(btn) {
  document.querySelectorAll('#reqMachineGrid .mbtn').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
  curMachine = { type:btn.dataset.type, unit:btn.dataset.unit, rate:btn.dataset.rate, max:parseFloat(btn.dataset.max) };
  const u = curMachine.unit==='hr' ? 'ล./ชม.' : 'ล./100กม.';
  document.getElementById('reqRateInfo').style.display='block';
  document.getElementById('reqRateText').textContent = curMachine.rate+' '+u;
  document.getElementById('reqMaxText').textContent   = '> '+curMachine.max+' '+u;
  document.getElementById('reqMeter_km').style.display = curMachine.unit==='km'?'':'none';
  document.getElementById('reqMeter_hr').style.display = curMachine.unit==='hr'?'':'none';
  liveCalc();
}

// ═══ AUTO FILL LAST ═══
function autoFillLast() {
  const plate = document.getElementById('reqPlateNo').value.trim().toUpperCase();
  const banner = document.getElementById('lastFuelBanner');
  if (!plate) { banner.style.display='none'; return; }
  const history = records.filter(r=>r.plateNo&&r.plateNo.toUpperCase().includes(plate))
    .sort((a,b)=>new Date(b.recordedAt||b.fuelDate)-new Date(a.recordedAt||a.fuelDate));
  if (history.length > 0) {
    const last = history[0];
    banner.style.display = 'block';
    let txt = last.fuelDate ? `วันที่ ${fmtD(last.fuelDate)}` : '';
    if (last.meterEnd) txt += `  มิเตอร์: ${last.meterEnd}`;
    if (last.actualLiters) txt += `  เติม: ${last.actualLiters} ล.`;
    document.getElementById('lastFuelText').textContent = txt || '—';
    if (last.fuelDate && !document.getElementById('reqLastFuelDate').value)
      document.getElementById('reqLastFuelDate').value = last.fuelDate;
    if (last.meterEnd) {
      const ms = document.getElementById('reqMileS'), hs = document.getElementById('reqHrS');
      if (ms && !ms.value) ms.value = last.meterEnd;
      if (hs && !hs.value) hs.value = last.meterEnd;
    }
  } else { banner.style.display='none'; }
}

// ═══ LIVE CALC ═══
function liveCalc() {
  if (!curMachine) return;
  const live = document.getElementById('reqCalcLive');
  const liters = parseFloat(document.getElementById('reqLiters').value)||0;
  const lastD  = document.getElementById('reqLastFuelDate').value;
  const thisD  = document.getElementById('reqFuelDate').value;
  let dist=0, rate=0, unit='';
  if (curMachine.unit==='km') {
    const s=parseFloat(document.getElementById('reqMileS').value)||0;
    const e=parseFloat(document.getElementById('reqMileE').value)||0;
    dist=e-s; rate=dist>0&&liters>0?liters/dist*100:0; unit='ล./100กม.';
  } else {
    const s=parseFloat(document.getElementById('reqHrS').value)||0;
    const e=parseFloat(document.getElementById('reqHrE').value)||0;
    dist=e-s; rate=dist>0&&liters>0?liters/dist:0; unit='ล./ชม.';
  }
  if (dist<=0) { live.style.display='none'; return; }
  live.style.display='block';
  document.getElementById('rcDateRange').textContent = (lastD&&thisD)?fmtD(lastD)+' → '+fmtD(thisD):(lastD||thisD||'—');
  document.getElementById('rcDist').textContent = dist.toFixed(1)+(curMachine.unit==='km'?' กม.':' ชม.');
  if (rate>0) {
    const over = rate>curMachine.max;
    document.getElementById('rcRate').textContent = rate.toFixed(2)+' '+unit;
    document.getElementById('rcStatus').textContent = over?'⚠️ เกินเรท!':'✅ ปกติ';
    document.getElementById('rcStatus').style.color = over?'#ff8c69':'#6fcf97';
  } else {
    document.getElementById('rcRate').textContent='—';
    document.getElementById('rcStatus').textContent='—';
  }
}

// ═══ PHOTOS ═══
function handleReqPhotos(input) {
  reqPhotos = [...reqPhotos,...Array.from(input.files)].slice(0,4);
  document.getElementById('reqPreviews').innerHTML = reqPhotos.map((f,i)=>
    `<div class="pt"><img src="${URL.createObjectURL(f)}"><button class="rp" onclick="reqPhotos.splice(${i},1);handleReqPhotos({files:[]})">✕</button></div>`).join('');
}
function handleFillPhotos(input) {
  fillPhotos = [...fillPhotos,...Array.from(input.files)].slice(0,4);
  document.getElementById('fillPreviews').innerHTML = fillPhotos.map((f,i)=>
    `<div class="pt"><img src="${URL.createObjectURL(f)}"><button class="rp" onclick="fillPhotos.splice(${i},1);handleFillPhotos({files:[]})">✕</button></div>`).join('');
}

// ═══ ADD TO CART ═══
function addToCart() {
  if (!curMachine) { toast('⚠️ กรุณาเลือกประเภทเครื่องจักร','warn'); return; }
  const plateNo=document.getElementById('reqPlateNo').value.trim();
  const driver =document.getElementById('reqDriverName').value.trim();
  const liters =document.getElementById('reqLiters').value;
  const reason =document.getElementById('reqReason').value.trim();
  const fuelDate=document.getElementById('reqFuelDate').value;
  if (!plateNo) { toast('⚠️ กรุณากรอกทะเบียน','warn'); return; }
  if (!driver)  { toast('⚠️ กรุณากรอกชื่อผู้ขับ','warn'); return; }
  if (!liters)  { toast('⚠️ กรุณากรอกจำนวนลิตร','warn'); return; }
  if (!reason)  { toast('⚠️ กรุณากรอกเหตุผล','warn'); return; }
  if (reqPhotos.length===0) { toast('⚠️ กรุณาถ่ายรูปมิเตอร์','warn'); return; }

  const lastFuelDate=document.getElementById('reqLastFuelDate').value;
  let meterStart='',meterEnd='',distOrHr='',consumeRate='',rateStatus='ไม่มีข้อมูล';
  if (curMachine.unit==='km') {
    meterStart=document.getElementById('reqMileS').value;
    meterEnd  =document.getElementById('reqMileE').value;
    const dist=parseFloat(meterEnd)-parseFloat(meterStart||0);
    if (dist>0) { distOrHr=dist.toFixed(0)+' กม.'; const r=parseFloat(liters)/dist*100; consumeRate=r.toFixed(2)+' ล./100กม.'; rateStatus=r>curMachine.max?'เกินเรท':'ปกติ'; }
  } else {
    meterStart=document.getElementById('reqHrS').value;
    meterEnd  =document.getElementById('reqHrE').value;
    const hrs =parseFloat(meterEnd)-parseFloat(meterStart||0);
    if (hrs>0)  { distOrHr=hrs.toFixed(1)+' ชม.'; const r=parseFloat(liters)/hrs; consumeRate=r.toFixed(2)+' ล./ชม.'; rateStatus=r>curMachine.max?'เกินเรท':'ปกติ'; }
  }

  cart.push({ id:'REQ'+Date.now(), fuelDate, lastFuelDate, plateNo,
    machineType:curMachine.type, machineUnit:curMachine.unit, machineMax:curMachine.max,
    liters:parseFloat(liters), project:document.getElementById('reqProject').value,
    driverName:driver, reason, meterStart, meterEnd, distOrHr, consumeRate, rateStatus,
    photoUrls:reqPhotos.map(f=>URL.createObjectURL(f)), requestedAt:new Date().toISOString() });

  renderCart(); clearItemForm();
  toast(`✅ เพิ่ม ${curMachine.type} ${plateNo} แล้ว`, 'success');
}

function removeFromCart(idx) { cart.splice(idx,1); renderCart(); }

function renderCart() {
  const sec=document.getElementById('cartSection');
  const items=document.getElementById('cartItems');
  if (cart.length===0) { sec.style.display='none'; return; }
  sec.style.display='block';
  document.getElementById('cartBadge').textContent=cart.length;
  const dates=[...new Set(cart.map(i=>i.fuelDate))];
  document.getElementById('cartDateLabel').textContent='📅 วันที่: '+dates.map(fmtD).join(', ');
  const totalL=cart.reduce((s,i)=>s+i.liters,0);
  document.getElementById('cartTotalLiters').textContent=totalL+' ลิตร';
  items.innerHTML=cart.map((item,idx)=>{
    const isOver=item.rateStatus==='เกินเรท';
    return `<div class="cart-item">
      <div style="flex:1">
        <div class="ci-lbl">${mi(item.machineType)} ${item.machineType} · ${item.plateNo}</div>
        <div class="ci-sub">👤 ${item.driverName}${item.project?' · '+item.project:''}${item.distOrHr?' · '+item.distOrHr:''}</div>
        ${item.consumeRate?`<div class="${isOver?'ci-warn':'ci-ok'}">${isOver?'⚠️':'✅'} ${item.consumeRate}</div>`:''}
      </div>
      <div class="ci-lt">${item.liters} ล.</div>
      <button class="ci-del" onclick="removeFromCart(${idx})">✕</button>
    </div>`;
  }).join('');
}

// ═══ BATCH PREVIEW ═══
