  const now=new Date();
  document.getElementById('lpcTime').textContent=`${now.getDate()}/${now.getMonth()+1}/${now.getFullYear()-543}  ${now.getHours()}:${String(now.getMinutes()).padStart(2,'0')} น.`;
  document.getElementById('lpcTotalBadge').textContent=cart.length+' รายการ';

  // Photos
  const photosEl=document.getElementById('lpcPhotos');
  const cnt=Math.min(cart.length,3);
  photosEl.className='lpc-photos '+(['','one','two','three'][cnt]);
  photosEl.innerHTML='';
  cart.slice(0,cnt).forEach(item=>{
    if(item.photoUrls&&item.photoUrls.length>0){
      const img=document.createElement('img'); img.src=item.photoUrls[0];
      img.style.cssText='width:100%;display:block;object-fit:cover;aspect-ratio:4/3';
      photosEl.appendChild(img);
    }
  });

  // Item cards
  document.getElementById('batchTableBody').innerHTML=cart.map((item,idx)=>{
    const isOver=item.rateStatus==='เกินเรท';
    const mLabel=item.machineUnit==='hr'?'ชม.':'กม.';
    const mLastLbl=item.lastFuelDate?fmtD(item.lastFuelDate):'—';
    const mNowLbl=fmtD(item.fuelDate);
    const meterBlock=item.meterEnd?`
      <div class="pc-meter">
        <div class="pcm-blk"><div class="pcm-lbl">${mLastLbl}</div><div class="pcm-val">${item.meterStart||'—'}</div></div>
        <div class="pcm-arrow">→</div>
        <div class="pcm-blk"><div class="pcm-lbl">${mNowLbl}</div><div class="pcm-val">${item.meterEnd}</div></div>
        ${item.distOrHr?`<div><div class="pcm-diff-lbl">ระยะ${item.machineUnit==='hr'?'ชม.':'ทาง'}</div><div class="pcm-diff-val">${item.distOrHr}</div></div>`:''}
      </div>` : '';
    const rateTag=item.consumeRate?`<div class="pc-rate ${isOver?'warn':'ok'}">${isOver?'⚠️':'✅'} ${item.consumeRate} ${isOver?'— เกินเรท':'— ปกติ'}</div>`:'';
    return `<div class="pc-item">
      <div class="pc-item-hd">
        <div class="pc-item-ml">
          <span class="pc-item-num">${idx+1}</span>
          <span>${mi(item.machineType)} ${item.machineType}</span>
          <span class="pc-plate">· ${item.plateNo}</span>
        </div>
        <div class="pc-liters">${item.liters} ล.</div>
      </div>
      <div class="pc-grid">
        <div><div class="pcf-lbl">ผู้ขับ/ควบคุม</div><div class="pcf-val">${item.driverName}</div></div>
        ${item.project?`<div><div class="pcf-lbl">หน่วยงาน</div><div class="pcf-val">${item.project}</div></div>`:''}
        <div style="grid-column:1/-1"><div class="pcf-lbl">งาน/เหตุผล</div><div class="pcf-val" style="font-size:12px;color:var(--gray-600)">${item.reason}</div></div>
      </div>
      ${meterBlock}${rateTag}
    </div>`;
  }).join('');

  const totalL=cart.reduce((s,i)=>s+i.liters,0);
  document.getElementById('batchTotalLiters').textContent=totalL+' ลิตร';

  // LINE bubble text
  let msg=`@PM แจ้งขอเบิกน้ำมัน ${fmtD(cart[0].fuelDate)}\nรวม ${cart.length} รายการ — ${totalL} ลิตร\n${'─'.repeat(24)}\n`;
  cart.forEach((item,idx)=>{
    const ml=item.machineUnit==='hr'?'ชม.':'ไมล์';
    msg+=`${idx+1}. ${item.machineType} ${item.plateNo} = ${item.liters} ล.\n`;
    if(item.lastFuelDate&&item.meterStart) msg+=`   ${fmtD(item.lastFuelDate)} ${ml}: ${item.meterStart}\n`;
    if(item.meterEnd) msg+=`   ${fmtD(item.fuelDate)} ${ml}: ${item.meterEnd}\n`;
    if(item.distOrHr) msg+=`   ระยะ: ${item.distOrHr}`;
    if(item.consumeRate) msg+=`  อัตรา: ${item.consumeRate}`;
    if(item.distOrHr||item.consumeRate) msg+='\n';
    if(item.rateStatus==='เกินเรท') msg+=`   ⚠️ เกินเรท!\n`;
    msg+=`   👤 ${item.driverName}${item.project?' ('+item.project+')':''}\n`;
    if(idx<cart.length-1) msg+=`${'─'.repeat(24)}\n`;
  });
  document.getElementById('lpcBubble').textContent=msg;

  const overItems=cart.filter(i=>i.rateStatus==='เกินเรท');
  const rbar=document.getElementById('lpcRateBar');
